<section class="card-container">
</section>

<div class="marca">
            <h2>TOYOTA</h2>
            <div class="pais">
                <img src="assets/japao.jpg" alt="card">
            </div>


            .marca {
    display: flex;
    flex-direction: column; /* 👈 ISSO RESOLVE */
    align-items: center;

    border-radius: 10px;
    background-color: rgba(255, 255, 255, 0.1);
    min-height: 50px;
    margin: 20px auto;
    backdrop-filter: blur(10px);
    border: #00000085 3px solid;

    width: 50%; /* melhor que margin-left/right gigante */
}

.marca h2 {
    font-size: 30px;
    color: rgb(255, 255, 255);
    font-family: 'Force Runner', sans-serif;
    margin-top: 10px;
}

.marca .pais {
    width: 200px;
    height: 200px;
    display: flex;
    justify-content: center;
    margin: 20px auto;
}


/* INFO ESCONDIDA */
.marca-info {
    max-height: 0;
    overflow: hidden;
    transition: 0.4s ease;
    color: white;
    margin-top: 10px;
}

/* QUANDO ABRE */
.marca-card.ativo .marca-info {
    max-height: 300px;
}